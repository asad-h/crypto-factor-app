# Keep the repo small for Streamlit Cloud. Only the dashboard-ready screener
# cache is committed so the app has data without needing private API keys.
cache/*
!cache/screener/
cache/screener/*
!cache/market_update/
cache/market_update/*
!cache/market_update/latest.pkl
!cache/screener/asset_master.parquet
!cache/screener/coingecko_markets.parquet
!cache/screener/factor_baskets.parquet
!cache/screener/factor_scores.parquet
!cache/screener/project_timeseries.parquet
!cache/screener/snapshot.parquet
!cache/screener/summary_timeseries.parquet
